  ('joule_per_mole_kelvin', '{"en-us": "Joule per mole-kelvin"}', '\mathrm{J}/(\mathrm{mol}\cdot\mathrm{K})', 'molar_entropy', 1, 'SI', 1, 0),
  ('coulomb_per_kilogram', '{"en-us": "Coulomb per kilogram"}', '\mathrm{C}/\mathrm{kg}', 'exposure', 1, 'SI', 1, 0),
  ('gray_per_second', '{"en-us": "Gray per second"}', '\mathrm{Gy}/\mathrm{s}', 'absorbed_dose_rate', 1, 'SI', 1, 0),
  ('watt_per_steradian', '{"en-us": "Watt per steradian"}', '\mathrm{W}/\mathrm{sr}', 'radiant_intensity', 1, 'SI', 1, 0),
