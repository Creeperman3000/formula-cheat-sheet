  ('katal_per_cubic_metre', '{"en-us": "Katal per cubic meter", "en-uk": "Katal per cubic metre"}', '\mathrm{kat}/\mathrm{m}^{3}', 'catalytic_activity_concentration', 1, 'SI', 1, 0),
  ('minute', '{"en-us": "Minute"}', '\mathrm{min}', 'time', 0, NULL, 60, 0),
  ('hour', '{"en-us": "Hour"}', '\mathrm{h}', 'time', 0, NULL, 3600, 0),
  ('day', '{"en-us": "Day"}', '\mathrm{d}', 'time', 0, NULL, 86400, 0),
  ('astronomical_unit', '{"en-us": "Astronomical unit"}', '\mathrm{au}', 'length', 0, NULL, 149597870700, 0),
  ('degree', '{"en-us": "Degree"}', '{}^{\circ}', 'angle', 0, NULL, 0.017453292519943295, 0),
  ('hectare', '{"en-us": "Hectare"}', '\mathrm{ha}', 'area', 0, NULL, 10000, 0),
  ('litre', '{"en-us": "Litre"}', '\mathrm{L}', 'volume', 0, NULL, 0.001, 0),
