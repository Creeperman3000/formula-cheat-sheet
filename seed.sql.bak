-- ============================================================
-- Update existing quantities' default_unit
-- ============================================================
UPDATE quantity SET default_unit = '[{"unit": "joule", "exponent": 1}]' WHERE id = 'energy' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "pascal", "exponent": 1}]' WHERE id = 'pressure' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "cubic_metre", "exponent": 1}]' WHERE id = 'volume' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "metre_per_second", "exponent": 1}]' WHERE id = 'velocity' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "metre_per_second_sq", "exponent": 1}]' WHERE id = 'acceleration' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "joule", "exponent": 1}]' WHERE id = 'work' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "joule", "exponent": 1}]' WHERE id = 'heat' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "joule", "exponent": 1}]' WHERE id = 'internal_energy' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "joule", "exponent": 1}, {"unit": "mole", "exponent": -1}, {"unit": "kelvin", "exponent": -1}]' WHERE id = 'gas_constant' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "mole", "exponent": 1}]' WHERE id = 'amount' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "kilogram", "exponent": 1}, {"unit": "metre", "exponent": 1}, {"unit": "second", "exponent": -1}]' WHERE id = 'momentum' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "candela", "exponent": 1}]' WHERE id = 'luminous_intensity' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "hertz", "exponent": 1}]' WHERE id = 'frequency' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "radian", "exponent": 1}]' WHERE id = 'angle' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "kilogram", "exponent": 1}, {"unit": "cubic_metre", "exponent": -1}]' WHERE id = 'density' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "volt", "exponent": 1}]' WHERE id = 'electric_potential' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "metre", "exponent": 1}]' WHERE id = 'wavelength' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "tesla", "exponent": 1}]' WHERE id = 'magnetic_field' AND default_unit IS NULL;
UPDATE quantity SET default_unit = '[{"unit": "newton", "exponent": 1}, {"unit": "metre", "exponent": -1}]' WHERE id = 'spring_constant' AND default_unit IS NULL;

-- Set subbranch for rotational mechanics quantities
UPDATE quantity SET subbranch = 'rotational_mechanics' WHERE id IN ('torque', 'angular_velocity', 'angular_acceleration');

-- Set base_si for SI base quantities
UPDATE quantity SET base_si = 1 WHERE id = 'luminous_intensity';
